// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                   String         @id @default(uuid())
  username             String         @unique
  email                String         @unique
  password             String
  name                 String
  avatar               String?
  twoFactorEnabled     Boolean        @default(false)
  loginAlertsEnabled   Boolean        @default(true)
  resetPasswordToken   String?
  resetPasswordExpiry  DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  sessions             AdminSession[]
}

model AdminSession {
  id           String    @id @default(uuid())
  adminId      String
  device       String
  ipAddress    String?
  userAgent    String?
  location     String?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([createdAt])
  @@index([revokedAt])
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  username    String    @unique
  password    String
  name        String
  avatar      String?
  coverImage  String?
  bio         String?
  gender      String? // Nam, Nữ, Khác
  dateOfBirth DateTime?
  address     String?
  phone       String?
  website     String?
  facebook    String?
  instagram   String?
  twitter     String?
  linkedin    String?
  role        String    @default("user") // 'user' | 'admin'
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  posts                Post[]
  comments             Comment[]
  likes                Like[]
  commentLikes         CommentLike[]
  followers            Follow[]                    @relation("UserFollowers")
  following            Follow[]                    @relation("UserFollowing")
  blockers             Block[]                     @relation("UserBlocks")
  blockedBy            Block[]                     @relation("UserBlockedBy")
  sentMessages         Message[]                   @relation("SentMessages")
  notifications        Notification[]
  lifeEvents           LifeEvent[]
  sharedPosts          Share[]
  savedPosts           SavedPost[]
  stories              Story[]
  pinnedMessages       Message[]                   @relation("PinnedMessages")
  customizationAsUserA ConversationCustomization[] @relation("UserAConversationCustomization")
  customizationAsUserB ConversationCustomization[] @relation("UserBConversationCustomization")
  customizationUpdated ConversationCustomization[] @relation("CustomizationUpdatedBy")
  reels                Reel[]
  reelLikes            ReelLike[]
  reelComments         ReelComment[]
  reelShares           ReelShare[]
  sentFriendRequests   FriendRequest[]             @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[]           @relation("ReceivedFriendRequests")
}

model Post {
  id           String   @id @default(uuid())
  content      String
  imageUrl     String?
  videoUrl     String?
  userId       String
  sharedPostId String? // ID của post được share (nếu đây là shared post)
  sharedReelId String?
  visibility   String   @default("public") // 'public' | 'friends' | 'private'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments   Comment[]
  likes      Like[]
  shares     Share[]
  savedPosts SavedPost[]
  sharedPost Post?       @relation("SharedPosts", fields: [sharedPostId], references: [id], onDelete: Cascade)
  sharedBy   Post[]      @relation("SharedPosts")
  sharedReel Reel?       @relation("PostSharedReel", fields: [sharedReelId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([sharedPostId])
  @@index([sharedReelId])
  @@index([visibility])
}

model Comment {
  id         String   @id @default(uuid())
  content    String
  imageUrl   String? // URL của ảnh trong comment
  postId     String
  userId     String
  imageIndex Int? // Index của ảnh trong post (null = comment chung cho post)
  parentId   String? // ID của comment cha (null = comment gốc, có giá trị = reply)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post    Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]     @relation("CommentReplies")
  likes   CommentLike[]

  @@index([postId])
  @@index([userId])
  @@index([postId, imageIndex])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  type      String   @default("like") // 'like', 'love', 'haha', 'wow', 'sad', 'angry'
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model CommentBannedKeyword {
  id        String   @id @default(uuid())
  keyword   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([keyword])
}

model Like {
  id         String   @id @default(uuid())
  postId     String
  userId     String
  type       String   @default("like") // 'like', 'love', 'haha', 'wow', 'sad', 'angry'
  imageIndex Int? // null = like post, number = like specific image
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, imageIndex])
  @@index([postId])
  @@index([userId])
  @@index([postId, imageIndex])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FriendRequest {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("pending") // 'pending' | 'accepted' | 'rejected'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model Message {
  id           String    @id @default(uuid())
  content      String
  imageUrl     String?
  videoUrl     String?
  audioUrl     String?
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  fileType     String?
  senderId     String
  receiverId   String
  replyToId    String? // ID of message being replied to
  read         Boolean   @default(false)
  deliveredAt  DateTime? // When message was delivered to recipient
  readAt       DateTime? // When message was read by recipient
  deletedBy    String[]  @default([]) // Array of user IDs who deleted this message
  unsent       Boolean   @default(false) // Message has been unsent by sender
  callType     String? // 'voice' | 'video' - Type of call
  callDuration Int? // Duration in seconds
  callStatus   String? // 'completed' | 'missed' | 'rejected' | 'no-answer'
  createdAt    DateTime  @default(now())
  pinnedById   String?
  pinnedAt     DateTime?

  sender    User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  reactions MessageReaction[]
  replyTo   Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("MessageReplies")
  pinnedBy  User?             @relation("PinnedMessages", fields: [pinnedById], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([replyToId])
  @@index([pinnedById])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String // '❤️', '😂', '😮', '😢', '😡', '👍'
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Notification {
  id            String   @id @default(uuid())
  type          String // 'like', 'comment', 'follow', 'unfollow', 'message'
  content       String
  userId        String // Người nhận thông báo
  actorId       String? // Người thực hiện hành động
  actorName     String? // Tên người thực hiện
  actorUsername String? // Username người thực hiện
  actorAvatar   String? // Avatar người thực hiện
  relatedId     String? // ID liên quan (postId, commentId, etc)
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([read])
}

model LifeEvent {
  id          String    @id @default(uuid())
  userId      String
  type        String // 'work', 'education', 'relationship', 'home', 'location', 'achievement', 'health', 'travel'
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  imageUrl    String?
  privacy     String    @default("public") // 'public', 'friends', 'private'
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model Share {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([userId, postId])
}

model SavedPost {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@index([postId])
}

model Story {
  id        String   @id @default(uuid())
  userId    String
  imageUrl  String?
  videoUrl  String?
  createdAt DateTime @default(now())
  expiresAt DateTime // Stories expire after 24 hours

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  views StoryView[]

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  userId    String
  createdAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@index([storyId])
  @@index([userId])
}

model MutedConversation {
  id          String   @id @default(uuid())
  userId      String // Người tắt thông báo
  mutedUserId String // Người bị tắt thông báo
  createdAt   DateTime @default(now())

  @@unique([userId, mutedUserId])
  @@index([userId])
  @@index([mutedUserId])
}

model ConversationCustomization {
  id               String   @id @default(uuid())
  userAId          String
  userBId          String
  themeId          String   @default("sunset")
  emoji            String   @default("👍")
  nicknameForUserA String?
  nicknameForUserB String?
  updatedById      String?
  createdAt        DateTime @default(now())
  changeSummary    String?
  updatedAt        DateTime @updatedAt

  userA     User  @relation("UserAConversationCustomization", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User  @relation("UserBConversationCustomization", fields: [userBId], references: [id], onDelete: Cascade)
  updatedBy User? @relation("CustomizationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Reel {
  id           String   @id @default(uuid())
  videoUrl     String
  thumbnailUrl String?
  description  String?
  shareContent String?
  userId       String
  sharedFromId String?
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes         ReelLike[]
  comments      ReelComment[]
  shares        ReelShare[]
  sharedFrom    Reel?         @relation("ReelShared", fields: [sharedFromId], references: [id], onDelete: Cascade)
  sharedBy      Reel[]        @relation("ReelShared")
  sharedAsPosts Post[]        @relation("PostSharedReel")

  @@index([userId])
  @@index([createdAt])
  @@index([sharedFromId])
}

model ReelLike {
  id        String   @id @default(uuid())
  reelId    String
  userId    String
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reelId, userId])
  @@index([reelId])
  @@index([userId])
}

model ReelComment {
  id        String   @id @default(uuid())
  content   String
  reelId    String
  userId    String
  parentId  String? // For replies
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reel    Reel          @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  ReelComment?  @relation("ReelCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies ReelComment[] @relation("ReelCommentReplies")

  @@index([reelId])
  @@index([userId])
  @@index([parentId])
}

model ReelShare {
  id        String   @id @default(uuid())
  reelId    String
  userId    String
  content   String?
  createdAt DateTime @default(now())

  reel Reel @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reelId])
  @@index([userId])
}
